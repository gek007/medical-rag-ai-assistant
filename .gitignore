# Environment variables — never commit real keys
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[oc]
.venv/
*.egg-info/

# Logs
*.log
logs/
!logs/.gitkeep

# Uploaded files
uploaded_docs/*
!uploaded_docs/.gitkeep

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Claude Code local settings
.claude/

# Playwright / test screenshots
*.png
